# Sakallı ortam değişkenleri — kopyalayıp .env olarak kaydedin
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/sakalli/public
# Tarayıcıda kullanılan yol öneki (başında / ile)
APP_BASE_PATH=/sakalli/public
# Logo: public/ altı göreli yol (Ayarlar boşken veya dosya yoksa). Örn. images/sakalli-logo.png
BRANDING_LOGO_PATH=images/sakalli-logo.png
SESSION_NAME=SAKALLI_SESSID

# Giriş brute-force sınırı (varsayılan 5 deneme / 900 sn). true: devre dışı (yalnızca güvenilir ortamda).
LOGIN_RATE_LIMIT_DISABLED=false
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sakalli
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# LDAP/SMTP şifrelemesi: boş bırakılırsa storage/secrets/app_encryption.key otomatik oluşturulur.
# Üretimde çok sunuculu / yedekte tutarlılık için uzun rastgele dize önerilir:
SETTINGS_ENCRYPTION_KEY=

# true: storage/logs/ldap.log içine adım adım DEBUG satırları (parola asla yazılmaz). Sorun giderme sonrası false yapın.
LDAP_LOG_DEBUG=false

LDAP_HOST=ldap://dc.kurum.local
LDAP_PORT=389
LDAP_USE_TLS=false
LDAP_BIND_DN=CN=service,OU=Service,DC=kurum,DC=local
LDAP_BIND_PASSWORD=gizli
# Tüm domainde ara: DC=kurum,DC=local — veya AD'deki gerçek OU DN (PowerShell: Get-ADOrganizationalUnit)
LDAP_BASE_DN=DC=kurum,DC=local
# İsteğe bağlı: kampanya ekranında OU listesi bu DN altında aranır. Boş bırakılırsa LDAP_BASE_DN kullanılır.
LDAP_OU_SEARCH_BASE=
# İsteğe bağlı: yalnızca bu OU adına (ou=) sahip birimler listelenir. Örnek: Cloud — LDAP_OU_NAME_FILTER=Cloud ve taban OU=OU=Units,DC=kurum,DC=local
LDAP_OU_NAME_FILTER=
# OU hedefi: AD’den okunan kullanıcı yerelde yoksa otomatik oluşturulur; rol (varsayılan report_viewer — panele OU şartı ayrı)
LDAP_OU_TARGET_ROLE=report_viewer
# Mail/UPN boşsa kullanıcı adı + bu alan ile e-posta üretilir (ör. kullanici@kurum.local)
LDAP_OU_TARGET_EMAIL_DOMAIN=
# Tek OU aramasında en fazla kaç AD kullanıcısı (binlerce hedef için artırın)
LDAP_OU_FETCH_LIMIT=10000
LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName=%s))
LDAP_USER_FILTER_UPN=(&(objectClass=user)(userPrincipalName=%s))
# Panel girişi: kullanıcı DN'inde bu alt dize yoksa giriş reddedilir. Boş bırakılırsa OU kontrolü yapılmaz.
# Örnek: OU=ITDept veya OU=Security,OU=Users,DC=kurum,DC=local içinde geçen ortak parça
LDAP_PANEL_ALLOWED_DN_SUBSTRING=
# true: AD doğrulaması sonrası yerel kullanıcı yoksa oluştur (kurum politikasına göre kapatın)
LDAP_AUTO_PROVISION=false
LDAP_AUTO_PROVISION_ROLE=report_viewer
SMTP_HOST=mail.kurum.local
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@kurum.local
SMTP_FROM_NAME=Sakallı Güvenlik Farkındalığı

# Takip linki için genel taban (kampanya bazlı override DB'de)
TRACKING_BASE_URL=http://localhost/sakalli/public

# Token uzunluğu (byte, random_bytes)
TRACKING_TOKEN_BYTES=32

# Cron process_queue.php her çalışmada en fazla kaç e-posta
EMAIL_QUEUE_BATCH_SIZE=25
